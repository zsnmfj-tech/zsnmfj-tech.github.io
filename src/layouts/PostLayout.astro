---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  deck?: string;
  date?: string;
  readtime?: string;
  tags?: string[];
  crumb?: string;
}
const { title, deck, date, readtime, tags = [], crumb = '笔记' } = Astro.props;
---
<BaseLayout title={title} description={deck}>
  <header class="post-head">
    <div class="read">
      <p class="crumb"><a href="/">首页</a> / {crumb}</p>
      <h1>{title}</h1>
      {deck && <p class="deck">{deck}</p>}
      <div class="post-meta">
        {date && <span>{date}</span>}
        {readtime && <span class="dot">·</span>}
        {readtime && <span>{readtime}</span>}
        {tags.length > 0 && <span class="dot">·</span>}
        {tags.map((t, i) => (
          <span class={`tag post-tag${i === 1 ? ' warm' : ''}`}>#{t}</span>
        ))}
      </div>
    </div>
  </header>
  <article class="read post-body">
    <slot />
  </article>
</BaseLayout>
