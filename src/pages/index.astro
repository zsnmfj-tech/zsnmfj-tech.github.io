---
import BaseLayout from '../layouts/BaseLayout.astro';
import NoteList from '../components/NoteList.astro';
import { getCollection } from 'astro:content';
import { site } from '../site.config';

// 取所有非草稿笔记，按日期倒序
const all = (await getCollection('notes', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const latest = all.slice(0, 6);

// 各栏目计数（按 type 字段）
const counts: Record<string, string> = {};
for (const col of site.columns) {
  const n = all.filter((x) => x.data.type === col.type).length;
  counts[col.id] = n > 0 ? `${n} ${col.unit}` : '即将开始';
}

---
<BaseLayout title={site.name}>
  <!-- Hero -->
  <section class="hero">
    <div class="wrap hero-grid">
      <div class="hero-copy">
        <p class="kicker">{site.kicker}</p>
        <h1>{site.name}</h1>
        <p class="tagline">{site.tagline}</p>
        <div class="dir-tags" aria-label="关注方向">
          {site.dirs.map((d, i) => (
            <span class={`tag${i === 0 ? ' solid' : ''}`}># {d}</span>
          ))}
        </div>
      </div>
      <aside class="hero-atlas" aria-label="观察坐标">
        <div class="atlas-topline">
          <span>观察坐标</span>
          <span>2026</span>
        </div>
        <svg class="hero-geom" viewBox="0 0 280 220" fill="none" aria-hidden="true">
          <g stroke="currentColor" stroke-width="1">
            <path d="M24 186L82 32h172l-58 154H24Z" opacity=".55"/>
            <path d="M72 186l68-88 62 88M82 32l58 66 58-66M140 98v88" opacity=".85"/>
          </g>
          <g fill="currentColor">
            <circle cx="140" cy="98" r="4"/>
            <circle cx="72" cy="186" r="3"/>
            <circle cx="202" cy="186" r="3"/>
            <circle cx="82" cy="32" r="3"/>
            <circle cx="198" cy="32" r="3"/>
          </g>
        </svg>
        <ol class="atlas-list">
          {site.dirs.map((d, i) => (
            <li><span>0{i + 1}</span>{d}</li>
          ))}
        </ol>
      </aside>
    </div>
  </section>

  <!-- About -->
  <section class="about-strip" id="about">
    <div class="wrap about-grid">
      <h3>{site.aboutTitle}</h3>
      <p set:html={site.about} />
    </div>
  </section>

  <!-- Latest notes -->
  <section class="section">
    <div class="wrap">
      <div class="section-head">
        <h2>最新笔记</h2>
        <span class="section-note">最近更新 · {latest.length} 篇</span>
      </div>
      <NoteList notes={latest} />
    </div>
  </section>

  <!-- Columns -->
  <section class="section">
    <div class="wrap">
      <div class="section-head">
        <h2>探索栏目</h2>
        <span class="section-note">四条持续更新的观察线索</span>
      </div>
      <div class="cols">
        {site.columns.map((col, i) => (
          <a class="col-card" href={`/columns/${col.id}/`} id={col.id}>
            <span class="col-index">0{i + 1}</span>
            {col.id === 'reading' && (
              <svg class="ico" viewBox="0 0 34 34" fill="none" stroke="currentColor" stroke-width="1.3" aria-hidden="true">
                <path d="M5 7 Q5 5 7 5 L17 5 L17 29 L7 29 Q5 29 5 27 Z"/>
                <path d="M29 7 Q29 5 27 5 L17 5 L17 29 L27 29 Q29 29 29 27 Z"/>
              </svg>
            )}
            {col.id === 'papers' && (
              <svg class="ico" viewBox="0 0 34 34" fill="none" stroke="currentColor" stroke-width="1.3" aria-hidden="true">
                <path d="M9 4 L22 4 L29 11 L29 30 L9 30 Z"/>
                <path d="M22 4 L22 11 L29 11"/>
                <line x1="13" y1="17" x2="25" y2="17"/>
                <line x1="13" y1="22" x2="25" y2="22"/>
                <line x1="13" y1="27" x2="21" y2="27"/>
              </svg>
            )}
            {col.id === 'landing' && (
              <svg class="ico" viewBox="0 0 34 34" fill="none" stroke="currentColor" stroke-width="1.3" aria-hidden="true">
                <circle cx="8" cy="9" r="2.6"/>
                <circle cx="26" cy="9" r="2.6"/>
                <circle cx="17" cy="25" r="2.6"/>
                <line x1="10.2" y1="10.6" x2="14.8" y2="23.4"/>
                <line x1="23.8" y1="10.6" x2="19.2" y2="23.4"/>
                <line x1="10.6" y1="9" x2="23.4" y2="9"/>
              </svg>
            )}
            {col.id === 'events' && (
              <svg class="ico" viewBox="0 0 34 34" fill="none" stroke="currentColor" stroke-width="1.3" aria-hidden="true">
                <path d="M17 3 C11 3 7 7 7 13 C7 21 17 31 17 31 C17 31 27 21 27 13 C27 7 23 3 17 3 Z"/>
                <circle cx="17" cy="13" r="3.6"/>
              </svg>
            )}
            <h4>{col.name}</h4>
            <p>{col.desc}</p>
            <span class="count">{counts[col.id]}</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
