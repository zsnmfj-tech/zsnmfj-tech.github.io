---
import { site } from '../site.config';
// 顶部导航。文案来自 site.config。
---
<header class="nav">
  <div class="wrap nav-inner">
    <a class="brand" href="/">
      <svg class="mark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true">
        <rect x="3" y="3" width="18" height="18"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="12" y1="3" x2="12" y2="21"/>
        <circle cx="12" cy="12" r="2.4" fill="#b08442" stroke="none"/>
      </svg>
      {site.name}
    </a>
    <nav class="nav-links" aria-label="主导航">
      {site.nav.map((n, i) => (
        <a href={n.href} class={i === site.nav.length - 1 ? 'always' : ''}>{n.label}</a>
      ))}
    </nav>
  </div>
</header>
